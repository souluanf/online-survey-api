@page "/surveys/{SurveyId:guid}/results"
@using System.Globalization
@using OnlineSurvey.Web.Models
@using OnlineSurvey.Web.Services
@inject ISurveyApiService SurveyService

<PageTitle>Resultados da Pesquisa</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="d-block mx-auto mt-8" />
}
else if (_results is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">Resultados não encontrados.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
        <MudText Typo="Typo.h4" Class="font-weight-bold">Resultados: @_results.SurveyTitle</MudText>
    </MudStack>
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-6">
        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Secondary" />
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
            Total de respostas: <strong>@_results.TotalResponses</strong>
        </MudText>
    </MudStack>

    @foreach (var question in _results.Questions)
    {
        <MudCard Elevation="2" Style="border-radius:12px" Class="mb-5">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Class="font-weight-bold">@question.QuestionText</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @foreach (var option in question.Options)
                {
                    <div class="mb-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                            <MudText Typo="Typo.body2" Class="font-weight-medium">@option.OptionText</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @option.Count votos &nbsp;—&nbsp; @option.Percentage.ToString("F1")%
                            </MudText>
                        </MudStack>
                        <MudProgressLinear Value="@option.Percentage"
                                           Max="100"
                                           Color="@GetProgressColor(option.Percentage)"
                                           Rounded="true"
                                           Size="Size.Large"
                                           Style="height:14px" />
                    </div>
                }
            </MudCardContent>
        </MudCard>
    }

    <MudButton Href="/surveys"
               Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.ArrowBack">
        Voltar às Pesquisas
    </MudButton>
}

@code {
    [Parameter]
    public Guid SurveyId { get; set; }

    private SurveyResultResponse? _results;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _results = await SurveyService.GetSurveyResultsAsync(SurveyId);
        _loading = false;
    }

    private static Color GetProgressColor(double percentage) => percentage switch
    {
        > 50 => Color.Success,
        > 25 => Color.Info,
        > 10 => Color.Warning,
        _ => Color.Default
    };
}
