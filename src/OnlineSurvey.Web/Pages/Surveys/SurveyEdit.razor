@page "/surveys/{Id:guid}/edit"
@using OnlineSurvey.Web.Models
@using OnlineSurvey.Web.Services
@inject ISurveyApiService SurveyService
@inject NavigationManager Navigation

<PageTitle>Editar Pesquisa</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="d-block mx-auto mt-8" />
}
else if (_survey == null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
        Pesquisa não encontrada.
    </MudAlert>
    <MudButton Href="/surveys" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack">
        Voltar
    </MudButton>
}
else if (_survey.Status != SurveyStatus.Draft)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-4">
        <MudText Typo="Typo.h6" Class="mb-1">Pesquisa não pode ser editada</MudText>
        <MudText>Apenas pesquisas em rascunho podem ser editadas. Esta pesquisa está com status: <strong>@GetStatusName(_survey.Status)</strong></MudText>
    </MudAlert>
    <MudButton Href="/surveys" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack">
        Voltar para Lista
    </MudButton>
}
else
{
    <MudText Typo="Typo.h4" Class="font-weight-bold mb-6">Editar Pesquisa</MudText>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">@_errorMessage</MudAlert>
    }

    @if (_saved)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">
            Pesquisa atualizada com sucesso!
        </MudAlert>
    }

    <MudCard Elevation="2" Style="border-radius:12px" Class="mb-5">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Informações da Pesquisa</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudTextField Label="Título *"
                          @bind-Value="_title"
                          Variant="Variant.Outlined"
                          Required="true"
                          Class="mb-4" />
            <MudTextField Label="Descrição"
                          @bind-Value="_description"
                          Variant="Variant.Outlined"
                          Lines="3"
                          AutoGrow="true" />
        </MudCardContent>
    </MudCard>

    <MudCard Elevation="2" Style="border-radius:12px" Class="mb-5">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Perguntas</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!_survey.Questions.Any())
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    Esta pesquisa não tem perguntas.
                </MudAlert>
            }
            else
            {
                @foreach (var question in _survey.Questions.OrderBy(q => q.Order))
                {
                    <MudCard Outlined="true" Style="border-radius:8px" Class="mb-3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Pergunta @question.Order</MudText>
                                    @if (question.IsRequired)
                                    {
                                        <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">Obrigatória</MudChip>
                                    }
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body1" Class="font-weight-bold mb-3">@question.Text</MudText>
                            <MudStack Spacing="1">
                                @foreach (var option in question.Options.OrderBy(o => o.Order))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Style="min-width:32px; font-weight:700">@((char)('A' + option.Order - 1))</MudChip>
                                        <MudText Typo="Typo.body2">@option.Text</MudText>
                                    </MudStack>
                                }
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }
            }
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-3">
                <MudText Typo="Typo.caption">Para editar perguntas e opções, exclua a pesquisa e crie uma nova.</MudText>
            </MudAlert>
        </MudCardContent>
    </MudCard>

    <MudStack Row="true" Spacing="2" Class="mb-6">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@(_saving || string.IsNullOrWhiteSpace(_title))"
                   OnClick="SaveChanges">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Salvar Alterações
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.CheckCircle"
                   Disabled="@_saving"
                   OnClick="ActivateSurvey">
            Ativar Pesquisa
        </MudButton>
        <MudButton Href="/surveys"
                   Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Voltar
        </MudButton>
    </MudStack>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private SurveyDetailResponse? _survey;
    private string _title = "";
    private string? _description;
    private bool _loading = true;
    private bool _saving;
    private bool _saved;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSurvey();
    }

    private async Task LoadSurvey()
    {
        _loading = true;
        _survey = await SurveyService.GetSurveyByIdAsync(Id);

        if (_survey != null)
        {
            _title = _survey.Title;
            _description = _survey.Description;
        }

        _loading = false;
    }

    private async Task SaveChanges()
    {
        _saving = true;
        _saved = false;
        _errorMessage = null;

        try
        {
            var request = new UpdateSurveyRequest(_title, _description);
            var result = await SurveyService.UpdateSurveyAsync(Id, request);

            if (result != null)
            {
                _survey = result;
                _saved = true;
            }
            else
            {
                _errorMessage = "Erro ao salvar alterações.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ActivateSurvey()
    {
        _saving = true;
        _errorMessage = null;

        try
        {
            var result = await SurveyService.ActivateSurveyAsync(Id, new ActivateSurveyRequest(null, null));

            if (result != null)
            {
                Navigation.NavigateTo("/surveys");
            }
            else
            {
                _errorMessage = "Erro ao ativar pesquisa.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private static string GetStatusName(SurveyStatus status) => status switch
    {
        SurveyStatus.Draft => "Rascunho",
        SurveyStatus.Active => "Ativa",
        SurveyStatus.Closed => "Encerrada",
        _ => status.ToString()
    };
}
