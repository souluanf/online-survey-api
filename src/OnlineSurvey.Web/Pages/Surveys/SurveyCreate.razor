@page "/surveys/create"
@using OnlineSurvey.Web.Models
@using OnlineSurvey.Web.Services
@inject ISurveyApiService SurveyService
@inject NavigationManager Navigation

<PageTitle>Criar Nova Pesquisa</PageTitle>

<MudText Typo="Typo.h4" Class="font-weight-bold mb-6">Criar Nova Pesquisa</MudText>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">@_errorMessage</MudAlert>
}

@if (_created)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">
        <MudText Typo="Typo.h6" Class="mb-2">Pesquisa criada com sucesso!</MudText>
        <MudText Class="mb-4">A pesquisa "<strong>@_title</strong>" foi criada como rascunho.</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" @onclick="ActivateAndGo">
                Ativar Pesquisa
            </MudButton>
            <MudButton Href="/surveys" Variant="Variant.Outlined" Color="Color.Inherit">
                Voltar para Lista
            </MudButton>
        </MudStack>
    </MudAlert>
}
else
{
    <EditForm Model="this" OnValidSubmit="HandleSubmit">
        <MudCard Elevation="2" Style="border-radius:12px" Class="mb-5">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Informações da Pesquisa</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField Label="Título *"
                              @bind-Value="_title"
                              Variant="Variant.Outlined"
                              Required="true"
                              Class="mb-4" />
                <MudTextField Label="Descrição"
                              @bind-Value="_description"
                              Variant="Variant.Outlined"
                              Lines="3"
                              AutoGrow="true" />
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="2" Style="border-radius:12px" Class="mb-5">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Configurações de Acesso</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudSelect T="SurveyAccessMode" Label="Modo de Acesso" @bind-Value="_accessMode" Variant="Variant.Outlined" Class="mb-4">
                    <MudSelectItem T="SurveyAccessMode" Value="@SurveyAccessMode.Anonymous">Público anônimo</MudSelectItem>
                    <MudSelectItem T="SurveyAccessMode" Value="@SurveyAccessMode.CodeByEmail">Código por email</MudSelectItem>
                    <MudSelectItem T="SurveyAccessMode" Value="@SurveyAccessMode.RequiresLogin">Requer login</MudSelectItem>
                </MudSelect>
                <MudCheckBox @bind-Value="_isPublic" Label="Pesquisa pública (visível na listagem)" Color="Color.Primary" Class="mb-4" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Dados coletados dos participantes</MudText>
                <MudCheckBox @bind-Value="_collectName" Label="Nome" Color="Color.Primary" />
                <MudCheckBox @bind-Value="_collectEmail" Label="Email" Color="Color.Primary" />
                <MudCheckBox @bind-Value="_collectAge" Label="Idade" Color="Color.Primary" />
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="2" Style="border-radius:12px" Class="mb-5">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Perguntas</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Success"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddQuestion">
                        Adicionar Pergunta
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (!_questions.Any())
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        Adicione pelo menos uma pergunta à pesquisa.
                    </MudAlert>
                }
                else
                {
                    @for (int q = 0; q < _questions.Count; q++)
                    {
                        var questionIndex = q;
                        var question = _questions[questionIndex];

                        <MudCard Outlined="true" Style="border-radius:8px; border-left: 4px solid var(--mud-palette-primary)" Class="mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Pergunta @(questionIndex + 1)</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="() => RemoveQuestion(questionIndex)" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudTextField Label="Texto da Pergunta *"
                                              @bind-Value="question.Text"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              Class="mb-3" />
                                <MudCheckBox @bind-Value="question.IsRequired"
                                             Label="Pergunta obrigatória"
                                             Color="Color.Primary"
                                             Class="mb-4" />

                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Opções de Resposta</MudText>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               OnClick="() => AddOption(questionIndex)">
                                        Adicionar Opção
                                    </MudButton>
                                </MudStack>

                                @if (!question.Options.Any())
                                {
                                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                                        Adicione pelo menos 2 opções de resposta.
                                    </MudAlert>
                                }
                                else
                                {
                                    @for (int o = 0; o < question.Options.Count; o++)
                                    {
                                        var optionIndex = o;
                                        var option = question.Options[optionIndex];
                                        var letter = (char)('A' + optionIndex);

                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Style="min-width:32px; font-weight:700">@letter</MudChip>
                                            <MudTextField @bind-Value="option.Text"
                                                          Placeholder="Texto da opção"
                                                          Variant="Variant.Outlined"
                                                          Required="true"
                                                          Margin="Margin.Dense"
                                                          Style="flex:1" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           Disabled="@(question.Options.Count <= 2)"
                                                           OnClick="() => RemoveOption(questionIndex, optionIndex)" />
                                        </MudStack>
                                    }
                                }
                            </MudCardContent>
                        </MudCard>
                    }
                }
            </MudCardContent>
        </MudCard>

        <MudStack Row="true" Spacing="2">
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(_saving || !IsValid())"
                       StartIcon="@(_saving ? null : Icons.Material.Filled.Save)">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Criar Pesquisa
            </MudButton>
            <MudButton Href="/surveys" Variant="Variant.Outlined" Color="Color.Default">
                Cancelar
            </MudButton>
        </MudStack>
    </EditForm>
}

@code {
    private string _title = "";
    private string? _description;
    private readonly List<QuestionModel> _questions = [];
    private bool _saving;
    private bool _created;
    private string? _errorMessage;
    private Guid _createdSurveyId;
    private SurveyAccessMode _accessMode = SurveyAccessMode.Anonymous;
    private bool _isPublic = true;
    private bool _collectName;
    private bool _collectEmail;
    private bool _collectAge;

    private SurveyCollectedFields CollectedFields =>
        (_collectName ? SurveyCollectedFields.Name : SurveyCollectedFields.None) |
        (_collectEmail ? SurveyCollectedFields.Email : SurveyCollectedFields.None) |
        (_collectAge ? SurveyCollectedFields.Age : SurveyCollectedFields.None);

    protected override void OnInitialized()
    {
        // Start with one question with two options
        AddQuestion();
    }

    private void AddQuestion()
    {
        var question = new QuestionModel
        {
            Text = "",
            IsRequired = true,
            Options = [new OptionModel { Text = "" }, new OptionModel { Text = "" }]
        };
        _questions.Add(question);
    }

    private void RemoveQuestion(int index)
    {
        _questions.RemoveAt(index);
    }

    private void AddOption(int questionIndex)
    {
        _questions[questionIndex].Options.Add(new OptionModel { Text = "" });
    }

    private void RemoveOption(int questionIndex, int optionIndex)
    {
        if (_questions[questionIndex].Options.Count > 2)
        {
            _questions[questionIndex].Options.RemoveAt(optionIndex);
        }
    }

    private bool IsValid()
    {
        if (string.IsNullOrWhiteSpace(_title)) return false;
        if (!_questions.Any()) return false;

        foreach (var question in _questions)
        {
            if (string.IsNullOrWhiteSpace(question.Text)) return false;
            if (question.Options.Count < 2) return false;
            if (question.Options.Any(o => string.IsNullOrWhiteSpace(o.Text))) return false;
        }

        return true;
    }

    private async Task HandleSubmit()
    {
        _saving = true;
        _errorMessage = null;

        try
        {
            var request = new CreateSurveyRequest(
                _title,
                _description,
                _questions.Select((q, qi) => new CreateQuestionRequest(
                    q.Text,
                    qi + 1,
                    q.IsRequired,
                    q.Options.Select((o, oi) => new CreateOptionRequest(o.Text, oi + 1)).ToList()
                )).ToList(),
                _accessMode,
                CollectedFields,
                _isPublic
            );

            var result = await SurveyService.CreateSurveyAsync(request);

            if (result != null)
            {
                _createdSurveyId = result.Id;
                _created = true;
            }
            else
            {
                _errorMessage = "Erro ao criar pesquisa. Verifique os dados e tente novamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ActivateAndGo()
    {
        var result = await SurveyService.ActivateSurveyAsync(_createdSurveyId, new ActivateSurveyRequest(null, null));
        if (result != null)
        {
            Navigation.NavigateTo($"/surveys/{_createdSurveyId}");
        }
    }

    private sealed class QuestionModel
    {
        public string Text { get; set; } = "";
        public bool IsRequired { get; set; } = true;
        public List<OptionModel> Options { get; set; } = [];
    }

    private sealed class OptionModel
    {
        public string Text { get; set; } = "";
    }
}
