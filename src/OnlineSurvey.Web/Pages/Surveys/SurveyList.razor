@page "/surveys"
@using OnlineSurvey.Web.Models
@using OnlineSurvey.Web.Services
@inject ISurveyApiService SurveyService

<PageTitle>Pesquisas</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <MudText Typo="Typo.h4" Class="font-weight-bold">Pesquisas</MudText>
    <MudButton Href="/surveys/create"
               Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Style="border-radius:8px">
        Nova Pesquisa
    </MudButton>
</MudStack>

<MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pt-6" @bind-ActivePanelIndex="_tabIndex">
    <MudTabPanel Text="@($"Ativas ({_activeSurveys.Count()})")">
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="d-block mx-auto" />
        }
        else if (!_activeSurveys.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Nenhuma pesquisa ativa no momento.
            </MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var survey in _activeSurveys)
                {
                    <MudItem xs="12" sm="6" lg="4">
                        <MudCard Elevation="2" Style="border-radius:12px; height:100%; border-top: 4px solid var(--mud-palette-success)">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Ativa</MudChip>
                                    </MudStack>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Class="mb-2">@survey.Title</MudText>
                                @if (!string.IsNullOrEmpty(survey.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@survey.Description</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @survey.QuestionCount perguntas &nbsp;|&nbsp; @survey.ResponseCount respostas
                                </MudText>
                            </MudCardContent>
                            <MudCardActions Class="flex-wrap gap-1 pa-3">
                                <MudButton Href="@($"/surveys/{survey.Id}")"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small">
                                    Responder
                                </MudButton>
                                <MudButton Href="@($"/surveys/{survey.Id}/results")"
                                           Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           Size="Size.Small">
                                    Resultados
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Warning"
                                           Size="Size.Small"
                                           @onclick="() => CloseSurvey(survey.Id)">
                                    Encerrar
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>

    <MudTabPanel Text="@($"Rascunhos ({_draftSurveys.Count()})")">
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="d-block mx-auto" />
        }
        else if (!_draftSurveys.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Nenhum rascunho. <MudLink Href="/surveys/create">Crie uma nova pesquisa</MudLink>.
            </MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var survey in _draftSurveys)
                {
                    <MudItem xs="12" sm="6" lg="4">
                        <MudCard Elevation="2" Style="border-radius:12px; height:100%; border-top: 4px solid var(--mud-palette-warning)">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">Rascunho</MudChip>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Class="mb-2">@survey.Title</MudText>
                                @if (!string.IsNullOrEmpty(survey.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@survey.Description</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @survey.QuestionCount perguntas
                                </MudText>
                            </MudCardContent>
                            <MudCardActions Class="flex-wrap gap-1 pa-3">
                                <MudButton Href="@($"/surveys/{survey.Id}/edit")"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small">
                                    Editar
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           Size="Size.Small"
                                           Disabled="@(_activating)"
                                           @onclick="() => ActivateSurvey(survey.Id)">
                                    @if (_activatingId == survey.Id)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                    }
                                    Ativar
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           @onclick="() => DeleteSurvey(survey.Id)">
                                    Excluir
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>

    <MudTabPanel Text="@($"Encerradas ({_closedSurveys.Count()})")">
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="d-block mx-auto" />
        }
        else if (!_closedSurveys.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Nenhuma pesquisa encerrada.
            </MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var survey in _closedSurveys)
                {
                    <MudItem xs="12" sm="6" lg="4">
                        <MudCard Elevation="2" Style="border-radius:12px; height:100%; border-top: 4px solid #94a3b8">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled">Encerrada</MudChip>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Class="mb-2">@survey.Title</MudText>
                                @if (!string.IsNullOrEmpty(survey.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@survey.Description</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @survey.QuestionCount perguntas &nbsp;|&nbsp; @survey.ResponseCount respostas
                                </MudText>
                            </MudCardContent>
                            <MudCardActions Class="pa-3">
                                <MudButton Href="@($"/surveys/{survey.Id}/results")"
                                           Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           Size="Size.Small">
                                    Ver Resultados
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>
</MudTabs>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@(_messageType == "alert-success" ? Severity.Success : _messageType == "alert-danger" ? Severity.Error : Severity.Info)"
              Variant="Variant.Filled"
              ShowCloseIcon="true"
              CloseIconClicked="() => _message = null"
              Class="mt-4">
        @_message
    </MudAlert>
}

@code {
    private IEnumerable<SurveyResponse> _activeSurveys = [];
    private IEnumerable<SurveyResponse> _draftSurveys = [];
    private IEnumerable<SurveyResponse> _closedSurveys = [];
    private bool _loading = true;
    private string _activeTab = "active";
    private int _tabIndex = 0;
    private bool _activating;
    private Guid? _activatingId;
    private string? _message;
    private string _messageType = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadSurveys();
    }

    private async Task LoadSurveys()
    {
        _loading = true;

        var result = await SurveyService.GetSurveysAsync(1, 100);
        if (result != null)
        {
            var allSurveys = result.Items.ToList();
            _activeSurveys = allSurveys.Where(s => s.Status == SurveyStatus.Active);
            _draftSurveys = allSurveys.Where(s => s.Status == SurveyStatus.Draft);
            _closedSurveys = allSurveys.Where(s => s.Status == SurveyStatus.Closed);
        }

        _loading = false;
    }

    private void ChangeTab(string tab)
    {
        _activeTab = tab;
    }

    private async Task ActivateSurvey(Guid surveyId)
    {
        _activating = true;
        _activatingId = surveyId;

        var result = await SurveyService.ActivateSurveyAsync(surveyId, new ActivateSurveyRequest(null, null));

        if (result != null)
        {
            _message = "Pesquisa ativada com sucesso!";
            _messageType = "alert-success";
            await LoadSurveys();
            _activeTab = "active";
            _tabIndex = 0;
        }
        else
        {
            _message = "Erro ao ativar pesquisa.";
            _messageType = "alert-danger";
        }

        _activating = false;
        _activatingId = null;
    }

    private async Task DeleteSurvey(Guid surveyId)
    {
        var success = await SurveyService.DeleteSurveyAsync(surveyId);

        if (success)
        {
            _message = "Pesquisa excluída com sucesso!";
            _messageType = "alert-success";
            await LoadSurveys();
        }
        else
        {
            _message = "Erro ao excluir pesquisa.";
            _messageType = "alert-danger";
        }
    }

    private async Task CloseSurvey(Guid surveyId)
    {
        var result = await SurveyService.CloseSurveyAsync(surveyId);

        if (result != null)
        {
            _message = "Pesquisa encerrada com sucesso!";
            _messageType = "alert-success";
            await LoadSurveys();
            _activeTab = "closed";
            _tabIndex = 2;
        }
        else
        {
            _message = "Erro ao encerrar pesquisa.";
            _messageType = "alert-danger";
        }
    }
}
