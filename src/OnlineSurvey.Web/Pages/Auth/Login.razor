@page "/login"
@inject FirebaseAuthService AuthService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">Entrar</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
            }

            <MudTextField @bind-Value="_email"
                          Label="E-mail"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_password"
                          Label="Senha"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Disabled="_loading" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="LoginWithEmail"
                       Disabled="_loading"
                       Class="mb-3">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Entrar
            </MudButton>

            <MudDivider Class="mb-3" />

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       FullWidth="true"
                       StartIcon="@Icons.Custom.Brands.Google"
                       OnClick="LoginWithGoogle"
                       Disabled="_loading"
                       Class="mb-4">
                Entrar com Google
            </MudButton>

            <MudText Align="Align.Center">
                Não tem conta? <MudLink Href="/register">Criar conta</MudLink>
            </MudText>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private string _email = "";
    private string _password = "";
    private string _errorMessage = "";
    private bool _loading;

    private async Task LoginWithEmail()
    {
        _errorMessage = "";
        _loading = true;
        try
        {
            await AuthService.SignInWithEmailAsync(_email, _password);
            Nav.NavigateTo("/surveys");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoginWithGoogle()
    {
        _errorMessage = "";
        _loading = true;
        try
        {
            await AuthService.SignInWithGoogleAsync();
            Nav.NavigateTo("/surveys");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
