@page "/"

<PageTitle>Online Survey - Sistema de Pesquisas</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="text-center py-12">
    <MudIcon Icon="@Icons.Material.Filled.Poll" Style="font-size:4rem; color: var(--mud-palette-primary);" Class="mb-4" />
    <MudText Typo="Typo.h3" Class="mb-4 font-weight-bold">Sistema de Pesquisas Online</MudText>
    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-4" Style="font-weight:400">
        Participe das pesquisas de opinião pública e ajude a construir um futuro melhor!
    </MudText>
    <MudDivider Class="my-6" />
    <MudText Typo="Typo.body1" Class="mb-8" Style="max-width:580px; margin-left:auto; margin-right:auto; color:#64748b">
        Nosso sistema permite que você responda a questionários de forma simples e segura.
        Os resultados são apresentados de forma sumarizada e transparente.
    </MudText>
    <MudStack Row="true" Justify="Justify.Center" Spacing="3">
        <MudButton Href="/surveys"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.List"
                   Style="border-radius:8px; padding: 12px 28px;">
            Ver Pesquisas Disponíveis
        </MudButton>
        <MudButton Href="/surveys/create"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Add"
                   Style="border-radius:8px; padding: 12px 28px;">
            Criar Nova Pesquisa
        </MudButton>
    </MudStack>
</MudContainer>

<MudGrid Justify="Justify.Center" Class="mt-8">
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2" Style="border-radius:12px; height:100%">
            <MudCardContent Class="text-center pa-8">
                <MudIcon Icon="@Icons.Material.Filled.TouchApp"
                         Style="font-size:2.5rem; color: var(--mud-palette-primary);"
                         Class="mb-4" />
                <MudText Typo="Typo.h6" Class="mb-2">Simples</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Perguntas de múltipla escolha fáceis de responder.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2" Style="border-radius:12px; height:100%">
            <MudCardContent Class="text-center pa-8">
                <MudIcon Icon="@Icons.Material.Filled.Security"
                         Style="font-size:2.5rem; color: var(--mud-palette-success);"
                         Class="mb-4" />
                <MudText Typo="Typo.h6" Class="mb-2">Seguro</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Suas respostas são armazenadas de forma segura.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2" Style="border-radius:12px; height:100%">
            <MudCardContent Class="text-center pa-8">
                <MudIcon Icon="@Icons.Material.Filled.BarChart"
                         Style="font-size:2.5rem; color: var(--mud-palette-warning);"
                         Class="mb-4" />
                <MudText Typo="Typo.h6" Class="mb-2">Transparente</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Veja os resultados em tempo real após votar.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>
