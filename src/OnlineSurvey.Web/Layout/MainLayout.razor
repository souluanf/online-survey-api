@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Poll" Color="Color.Inherit" Href="/" />
        <MudText Typo="Typo.h6" Class="ml-1 mr-4 font-weight-bold" Style="letter-spacing:0.03em">
            <MudLink Href="/" Color="Color.Inherit" Underline="Underline.None">Online Survey</MudLink>
        </MudText>
        <MudSpacer />
        <MudButton Href="/surveys"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.List"
                   Variant="Variant.Text"
                   Class="mr-1">
            Pesquisas
        </MudButton>
        <MudButton Href="/surveys/create"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.AddCircleOutline"
                   Variant="Variant.Outlined"
                   Class="mr-2">
            Nova Pesquisa
        </MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6366f1",
            PrimaryDarken = "#4f46e5",
            PrimaryLighten = "#818cf8",
            Secondary = "#f59e0b",
            Success = "#10b981",
            Warning = "#f59e0b",
            Error = "#ef4444",
            Info = "#3b82f6",
            AppbarBackground = "#6366f1",
            DrawerBackground = "#fafafa",
            Background = "#f8fafc",
            Surface = "#ffffff",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Roboto", "sans-serif"],
            },
            H1 = new H1Typography { FontSize = "2rem", FontWeight = "700" },
            H2 = new H2Typography { FontSize = "1.5rem", FontWeight = "600" },
            H5 = new H5Typography { FontSize = "1.1rem", FontWeight = "600" },
            H6 = new H6Typography { FontSize = "1rem", FontWeight = "600" },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px",
        }
    };
}
